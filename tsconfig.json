{
	"compilerOptions": {
		"target": "ES2022",
		"module": "commonjs",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"strict": true,
		"noImplicitAny": true,
		"noEmit": true,
		"resolveJsonModule": true,
		"types": ["node"]
	},
	"include": ["tests/**/*.ts", "playwright.config.ts"]
}
